{
  "name": "react-native-video-encoder",
  "version": "0.1.0",
  "description": "On-device PNG-sequence to MP4 encoder for React Native and Expo. No FFmpeg, no GPL. Just the platform video encoders.",
  "source": "./src/index.ts",
  "main": "./lib/module/index.js",
  "module": "./lib/module/index.js",
  "react-native": "./src/index.ts",
  "types": "./lib/typescript/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "react-native": "./src/index.ts",
      "types": "./lib/typescript/index.d.ts",
      "default": "./lib/module/index.js"
    },
    "./app.plugin": "./app.plugin.js",
    "./app.plugin.js": "./app.plugin.js",
    "./package.json": "./package.json"
  },
  "files": [
    "src",
    "lib",
    "ios",
    "android/src",
    "android/build.gradle",
    "android/proguard-rules.pro",
    "plugin",
    "app.plugin.js",
    "react-native-video-encoder.podspec"
  ],
  "sideEffects": false,
  "codegenConfig": {
    "name": "RNImageSequenceEncoderSpec",
    "type": "modules",
    "jsSrcsDir": "./src",
    "android": {
      "javaPackageName": "com.reactnativeimagesequenceencoder"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Rednegniw/react-native-video-encoder.git",
    "directory": "packages/react-native-video-encoder"
  },
  "keywords": [
    "react-native",
    "expo",
    "video",
    "encoder",
    "image-sequence",
    "mp4",
    "png-to-mp4",
    "mediacodec",
    "avassetwriter",
    "h264",
    "turbomodule"
  ],
  "author": "Antonin Wingender",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/Rednegniw/react-native-video-encoder/issues"
  },
  "homepage": "https://github.com/Rednegniw/react-native-video-encoder#readme",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "prepare": "bob build",
    "prepublishOnly": "tsc --noEmit",
    "check-types": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write ."
  },
  "peerDependencies": {
    "react": ">=18",
    "react-native": ">=0.73",
    "expo": ">=54.0.0"
  },
  "peerDependenciesMeta": {
    "expo": {
      "optional": true
    }
  },
  "devDependencies": {
    "react-native-builder-bob": "^0.40.18",
    "typescript": "~5.9.2"
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      [
        "module",
        {
          "esm": true
        }
      ],
      [
        "typescript",
        {
          "project": "tsconfig.build.json"
        }
      ]
    ]
  }
}
