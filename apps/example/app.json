{
  "expo": {
    "name": "Video Encoder Example",
    "slug": "view-recorder-example",
    "version": "1.0.0",
    "orientation": "portrait",
    "plugins": [
      "react-native-view-recorder",
      [
        "expo-media-library",
        {
          "photosPermission": "Allow $(PRODUCT_NAME) to save videos to your camera roll.",
          "savePhotosPermission": "Allow $(PRODUCT_NAME) to save videos to your camera roll."
        }
      ]
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.rednegniw.viewrecorder.example"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#ffffff"
      },
      "package": "com.rednegniw.viewrecorder.example"
    }
  }
}
